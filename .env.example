# Gemini (also referenced in vite.config via loadEnv for the client bundle)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Server: signs the Drive OAuth cookie (Vercel serverless + local). Invent any long random string — e.g. openssl rand -hex 32
# Required in production so the pt_drive_token cookie cannot be forged. After first deploy with this set, users may need to "Login" again once.
SESSION_SECRET=""

# Google OAuth (Express server / local dev — not prefixed with VITE_)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APP_URL="http://localhost:3000"

# ElevenLabs (server-side only: Vercel Function / local Express proxy)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="c6SfcYrb2t09NHXiT80T"

# Firebase web app — required for the browser (must use VITE_ prefix)
# Copy values from Firebase Console → Project settings → Your apps → SDK snippet
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# Firestore: optional override. Omit to use the project’s named AI Studio DB (see src/lib/firebase.ts). Set "(default)" for the default database only.
# VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
# Analytics: only if Google Analytics is enabled — same config block may show "measurementId": "G-XXXX". Otherwise leave empty.
VITE_FIREBASE_MEASUREMENT_ID=""
