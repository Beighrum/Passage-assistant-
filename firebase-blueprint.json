{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session between a user and the assistant",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["public", "internal"] },
        "title": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mode", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "An individual message within a chat session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "image": { "type": "string", "description": "Base64 or URL of image" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "User chat sessions"
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a session"
    }
  }
}
